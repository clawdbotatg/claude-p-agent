# secrets — never commit
.env

# private session notes (BRAIN_DIRS)
notes/

# your real persona — gitignored so personality changes never hit the public repo.
# Only the ROOT one is private; CLAUDE.md.example is the committed template, and
# examples/*/CLAUDE.md are committed (generic). The leading slash anchors to root.
/CLAUDE.md

# private tool overlay — your agent-specific tools (and their runtime state) live
# here and are never committed. Generic, shareable tools go in tools/ directly and
# ARE committed. Only the convention's README is tracked.
tools/local/*
!tools/local/README.md

# runtime / caches
*.pyc
__pycache__/
.DS_Store

# local sibling-repo checkouts (see ARCHITECTURE.md — not part of claude-p-agent)
/clawd-harness/
/clawd-video-chat/

# example tool runtime state (tokens, registries, logs the agent generates)
*.token.json
.*-token.json
*-log.jsonl

# engine-owned conversation memory (session-id store)
.memory/

# modules — each is its own git repo, pinned by modules.lock (which IS tracked)
/modules/

# generated per-spawn from hooks.base.json + modules/*/hooks.json (see agent.py)
.hooks.generated.json
.mcp.generated.json

# watchdog failure counter
.watchdog-fails

# last smoke result (read by tools/self status)
.smoke-last

# human-touched guard override (see tools/guard-check) — never committed
.guard-ok
