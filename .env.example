# claude-p-agent configuration — copy to .env and fill in.
# .env is gitignored. Never commit real secrets.

# ── core (all optional; defaults are sensible) ───────────────────────────────
# AGENT_DIR=/path/to/persona/home     # where AGENT.md lives (default: repo root)
# CLAUDE_BIN=claude                    # path to the claude CLI
# BRAIN_DIRS=/path/to/random-agent/notes   # session memory (--add-dir); gitignored

# CLAUDE_ARGS=                          # extra CLI flags on every turn

# ── adapter-only CLI locks (read by adapters/, not agent.py) ─────────────────
# CLAUDE_ARGS_PUBLIC=--permission-mode plan --disallowedTools Write Edit Bash

# ── import path for external adapters (clawd-video-chat cc-bridge) ──────────
# CLAUDE_P_AGENT_HOME=/path/to/claude-p-agent
# ── telegram adapter (adapters/telegram.py / ./tg.sh) ───────────────────────
# Owner DM uses adapters/prompts/private.md; others use public.md + CLAUDE_ARGS_PUBLIC.
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# TELEGRAM_OWNER_ID=987654321

# ── your tools' secrets go here, referenced by name from AGENT.md ────────────
# SERVICE_TOKEN=
# SOME_API_KEY=
