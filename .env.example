# claude-p-agent configuration — copy to .env and fill in.
# .env is gitignored. Never commit real secrets.

# ── core (all optional; defaults are sensible) ───────────────────────────────
# AGENT_DIR=/path/to/persona/home     # where CLAUDE.md lives (default: repo root)
# CLAUDE_BIN=claude                    # path to the claude CLI
# BRAIN_DIRS=/path/to/notes            # session memory (--add-dir); gitignored if under repo

# CLAUDE_ARGS=                          # extra CLI flags on every turn

# ── import path for external adapters (e.g. clawd-video-chat cc-bridge) ─────
# CLAUDE_P_AGENT_HOME=/path/to/claude-p-agent

# ── modules (each documents its vars in its own MODULE.md) ──────────────────
# CLAUDE_P_MODULES=                    # override modules dir (default: AGENT_DIR/modules)
# GH_OWNER=clawdbotatg                 # owner for tools/module publish

# modules/router — subscription routing
# CLAUDE_P_ROUTER=1                    # 0 disables
# CLAUDE_P_ROUTER_TTL=600              # usage cache seconds
# CLAWD_ACCOUNTS_DIR=~/.clawd-accounts

# modules/telegram — see its MODULE.md before starting
# TELEGRAM_BOT_TOKEN=                  # from @BotFather — a credential, guard it
# TELEGRAM_ALLOWED_IDS=                # comma-separated numeric user ids (@userinfobot)
# TELEGRAM_POLL_TIMEOUT=50

# ── your tools' secrets go here, referenced by name from CLAUDE.md ─────────
# SERVICE_TOKEN=
# SOME_API_KEY=
