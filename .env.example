# claude-p-agent configuration — copy to .env and fill in.
# .env is gitignored. Never commit real secrets.

# ── core (all optional; defaults are sensible) ───────────────────────────────
# AGENT_DIR=/path/to/persona/home     # where AGENT.md lives (default: repo root)
# CLAUDE_BIN=claude                    # path to the claude CLI
# BRAIN_DIRS=~/notes:~/knowledge       # extra readable dirs, ':'-separated (--add-dir)

# ── per-channel CLI flags = the real security lock ───────────────────────────
# The prompts/ files state the trust policy; these flags ENFORCE it. Lock the
# public channel down to read-only tools so an untrusted message physically
# cannot do harm. Tune the tool lists to your setup.
# CLAUDE_ARGS_PUBLIC=--permission-mode plan --disallowedTools Write Edit Bash
# CLAUDE_ARGS_PRIVATE=--permission-mode acceptEdits
# CLAUDE_ARGS=                          # flags applied to every turn, any channel

# ── your tools' secrets go here, referenced by name from AGENT.md ────────────
# SERVICE_TOKEN=
# SOME_API_KEY=
